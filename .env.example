# atreoAGENT environment variables — sample.
#
# Copy this file to `.env` (or set the variables in your shell / your
# docker-compose env: block) before running the agent. Every variable
# is OPTIONAL: the agent ships with sensible defaults and generates its
# own secrets (identity key, WireGuard key, notify API key, admin pin)
# at first run.
#
# The complete reference, with platform-specific notes, lives at
# https://docs.atreolink.com.

# --- data + WireGuard --------------------------------------------------

# Where the agent persists its state (config, keys, ACL, allocator).
# Default: /var/lib/atreoagent (mounted from ./data in docker-compose.yml).
# DATA_DIR=/var/lib/atreoagent

# WireGuard UDP listen port. Default: 51820.
# WG_PORT=51820

# Tunnel firewall — confines peers to the proxy ports + ICMP. Default: enabled.
# Set to "false" only if you have unusual requirements and accept that every
# host port becomes reachable to every paired device.
# WG_FIREWALL_ENABLED=true

# --- public endpoint ---------------------------------------------------

# Manual public endpoint, used only if UPnP / NAT-PMP fail.
# Set ENDPOINT_IP if you've manually forwarded the port — it tells the agent it
# has a usable public path, so it advertises the direct endpoint instead of the
# relay (see below).
# ENDPOINT_IP=
# ENDPOINT_PORT=51820

# --- CGNAT relay (fallback) --------------------------------------------

# The relay keeps the agent reachable when no direct inbound path exists (CGNAT,
# or UPnP/NAT-PMP failed and no manual forward). It's fallback-only: the agent
# uses it ONLY when it can't open or reach a public port, and the coordination
# service must also have the relay enabled and grant this device. Default: true.
# Set to false to opt this agent out of relaying entirely. The relay host,
# control URL and port all come from the grant — there is nothing else to set
# here. Behind CGNAT, manual port-forwarding can't help; the agent detects this
# and relays automatically.
# RELAY_ENABLED=true

# Force a relay session even when a usable public path exists, so a relay
# endpoint is always available to hand to clients (clients still prefer
# LAN/direct — the relay stays a fallback for them). Default false.
# RELAY_FORCE=true

# --- reverse proxy -----------------------------------------------------

# Disable the built-in proxy if you'd rather front the agent with Caddy /
# Traefik / nginx (use the forward-auth endpoint instead). Default: true.
# PROXY_ENABLED=true

# Proxy listen ports.
# PROXY_HTTP_PORT=80
# PROXY_HTTPS_PORT=443

# Forward-auth endpoint port (bound to the WireGuard server IP).
# PROXY_AUTH_PORT=9091

# CIDRs of upstream reverse proxies whose X-Forwarded-* headers may be
# trusted on the forward-auth endpoint. Comma-separated. Empty = trust
# only the TCP peer address (recommended). Set this only to the address
# of your own proxy.
# PROXY_TRUSTED_PROXIES=10.0.0.0/24

# --- local notification API -------------------------------------------

# Port the local push-notification HTTP API binds. Default: 9876.
# NOTIFY_PORT=9876

# --- SMTP-to-push gateway (opt-in) -----------------------------------

# Enable the LAN SMTP gateway. Off by default.
# SMTP_ENABLED=false

# Bind address. LAN-only by design — keep this on a private network.
# SMTP_LISTEN=0.0.0.0:2525

# Max accepted message size in bytes. Default: 1048576 (1 MiB).
# SMTP_MAX_MESSAGE_BYTES=1048576

# Per-source-IP rate limit (messages per minute). Default: 5.
# SMTP_RATE_PER_MINUTE=5

# Advertise STARTTLS on the same port using a self-signed cert
# persisted under DATA_DIR. Opportunistic encryption for clients
# that refuse plaintext SMTP (e.g. Grafana); not server authentication.
# Clients must skip cert verification.
# SMTP_TLS_ENABLED=false

# Catch-all recipient. Mail sent to an address that doesn't match any
# member is delivered to this member instead of being rejected. Must be an
# existing member's email address. Empty (default) rejects unknown recipients.
# SMTP_CATCH_ALL=
